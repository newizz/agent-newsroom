{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Hooks update office/status.json so the Virtual Office UI shows real-time agent activity. Also triggers Gist sync if configured.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh ${CLAUDE_HOOK_AGENT:-intake} busy 'spawning subagent'"
          }
        ]
      },
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh researcher busy 'searching the web'"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh builder busy 'writing dashboard'"
          }
        ]
      },
      {
        "matcher": "Bash\\(\\./scripts/deep-research\\.sh.*\\)|Bash\\(uv run.*notebooklm.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh deep-researcher busy 'NotebookLM research'"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh ${CLAUDE_HOOK_AGENT:-intake} idle ''"
          }
        ]
      },
      {
        "matcher": "Bash\\(\\./scripts/deep-research\\.sh.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh deep-researcher idle ''"
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/update-status.sh --reset"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash($CLAUDE_PROJECT_DIR/scripts/*)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(jq *)",
      "Bash(uv *)",
      "WebSearch",
      "WebFetch",
      "Task"
    ]
  }
}
